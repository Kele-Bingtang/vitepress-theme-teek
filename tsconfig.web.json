{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "preserve",
    "lib": ["esnext", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": [
    "typings",
    "packages/**/*.ts",
    "packages/**/*.d.ts",
    "packages/**/*.vue",
    "build/**/*.ts",
    "build/**/*.d.ts",
    "plugins/**/*.ts",
    "plugins/**/*.d.ts"
  ],
  "exclude": ["**/node_modules", "**/dist", "**/*.md"]
}
